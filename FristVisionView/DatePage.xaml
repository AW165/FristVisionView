<UserControl x:Class="FirstVisionView.DatePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FirstVisionView"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1600">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>

            <ColumnDefinition Width=" 1*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>
        <Border Grid.RowSpan="2"  HorizontalAlignment="Stretch" VerticalAlignment="Stretch" CornerRadius="80"  Style="{StaticResource BorderStyle}" Margin="10,10,10,10"/>

        <Border Grid.Column="1"  CornerRadius="80" Style="{StaticResource BorderStyle}" Margin="10,10,10,10"/>
        <Border  Grid.Column="1" Grid.Row="1" HorizontalAlignment="Stretch" VerticalAlignment ="Stretch" CornerRadius="80" Style="{StaticResource BorderStyle}" Margin="10,10,10,10"/>

    </Grid>
</UserControl>
