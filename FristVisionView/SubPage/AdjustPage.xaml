<UserControl x:Class="FirstVisionView.AdjustPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FirstVisionView"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1600">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1.5*"/>
        </Grid.ColumnDefinitions>
        <!--参数区域,裁剪必须开，否则卡片会被拖出界面-->
        <Border Grid.Column="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="Transparent" ClipToBounds="True" IsHitTestVisible="False">
            <Grid>
                <Canvas RenderTransformOrigin="0.5,0.5">
                    <!--参数Card1-->
                    <Border Height="150" Width="250" Background="#FFFFFF"  CornerRadius="20">
                        <Border.Effect >
                            <DropShadowEffect ShadowDepth="1"       
                  BlurRadius="10"
                  Color="#20000000"
                  Opacity="0.3"/>
                        </Border.Effect>
                    </Border>
                    <!--参数Card2-->
                    <Border Height="150" Width="250" Background="#FFFFFF"  CornerRadius="20">
                        <Border.Effect >
                            <DropShadowEffect ShadowDepth="1"       
                                              BlurRadius="10"
                                              Color="#20000000"
                                              Opacity="0.3"/>
                         </Border.Effect>
                    </Border>
                    <!--参数Card3-->
                    <Border Height="150" Width="250" Background="#FFFFFF" CornerRadius="20">
                        <Border.Effect >
                            <DropShadowEffect ShadowDepth="1"       
                                              BlurRadius="10"
                                              Color="#20000000"
                                              Opacity="0.3"/>
                        </Border.Effect>
                    </Border>
                </Canvas>
                <Canvas
                    x:Name="ParamCanvas"
                    Panel.ZIndex="1"
                    
                    IsHitTestVisible="False" MouseLeftButtonDown="Canvas_MouseLeftButtonDown" MouseLeftButtonUp="Canvas_MouseLeftButtonUp" MouseMove="Canvas_MouseMove">
                    <Rectangle x:Name="SelectionBox"
                               Stroke="Blue"
                               StrokeThickness="1"
                               Fill="#330000ff"
                               Visibility="Collapsed">
                    </Rectangle>
                    
                </Canvas>
            </Grid>
            
        </Border>
        <!--右侧区域-->
        <Grid Grid.Column="1" Grid.Row="1" >
            <Grid.RowDefinitions>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="19*"/>
            </Grid.RowDefinitions>
            <!--图像显示调整栏的底色-->
            <Border Background="#FFFFFF"  BorderBrush="#FFFFFF" HorizontalAlignment="Stretch" >
                <!-- 轻微垂直偏移 -->
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="1"       
                    BlurRadius="10"
                    Color="#20000000"
                    Opacity="0.3"/>
                </Border.Effect>
            </Border>
            <!--图像栏布局-->
            <!--图层选择列表-->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,0">
                <ComboBox x:Name="LayerSelection" Width="150" MaxHeight="35" Style="{StaticResource ComboboxStyle}"/>
                <ComboBox x:Name="CameraSelection"   Margin="30,0,0,0"  Width="100" MaxHeight="35" Style="{StaticResource ComboboxStyle}"/>
                <!--放大-->
                <Button x:Name="Enlarge" Margin="20,0,0,0" Content="➕" FontSize="25" Foreground="Gray" local:ButtonHelp.CornerRadius="17.5"  Style="{StaticResource ButtonStyle}" />
                <!--缩小-->
                <Button x:Name="Reduce" Margin="20,0,0,0" Content="➖" FontSize="25" Foreground="Gray" local:ButtonHelp.CornerRadius="17.5"  Style="{StaticResource ButtonStyle}" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="60"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="R:" Grid.Column="1" HorizontalAlignment="Center" FontSize="20"/>
                    <Label x:Name="RValue" Content="255" Grid.Column="2"  HorizontalAlignment="Center" FontSize="20"/>
                    <Label Content="G:"  Grid.Column="3" HorizontalAlignment="Center" FontSize="20"/>
                    <Label x:Name="GValue" Content="255"  Grid.Column="4" HorizontalAlignment="Center" FontSize="20"/>
                    <Label Content="B:" Grid.Column="5" HorizontalAlignment="Center" FontSize="20"/>
                    <Label x:Name="BValue" Content="255"  Grid.Column="6" HorizontalAlignment="Center" FontSize="20"/>
                    <Label Content="H:" Grid.Column="7" HorizontalAlignment="Center" FontSize="20"/>
                    <Label x:Name="HValue" Content="255" Grid.Column="8" HorizontalAlignment="Center" FontSize="20"/>
                    <Label Content="S:" Grid.Column="9" HorizontalAlignment="Center" FontSize="20"/>
                    <Label x:Name="SValue" Content="255"  Grid.Column="10" HorizontalAlignment="Center" FontSize="20"/>
                    <Label Content="V:" Grid.Column="11" HorizontalAlignment="Center" FontSize="20"/>
                    <Label x:Name="VValue" Content="255"  Grid.Column="12" HorizontalAlignment="Center" FontSize="20"/>
                </Grid>

            </StackPanel>
            <!--图像显示窗口-->
            <Image x:Name="imgDisplay" Grid.Row="1" Grid.Column="0" Source="/Pictrue.jpg"
                   Stretch="None">
                <!--图像操作：旋转/平移/缩放-->
                <Image.RenderTransform>
                    <!--缩放组合-->
                    <TransformGroup>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                        <TranslateTransform X="0" Y="0"/>
                    </TransformGroup>
                </Image.RenderTransform>
            </Image>
            <!--ROI区域-->
            <Canvas Grid.Row="1" Grid.Column="0" x:Name="ROI" Background="Transparent" IsHitTestVisible="True" RenderTransform="{Binding ElementName=imgDisplay,Path=RenderTransform}" />
        </Grid>
        
    </Grid>
</UserControl>
