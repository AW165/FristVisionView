<UserControl x:Class="FirstVisionView.SettingPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FirstVisionView"
             mc:Ignorable="d" 
             d:DesignHeight="941" d:DesignWidth="1860">
    <Grid>
        <Border Background="#F5F5F7" >
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="1*"/>
                </Grid.RowDefinitions>
                <Border Background="#ffffff" Margin="25,25,25,25" CornerRadius="35" Style="{StaticResource BorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>

                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="1*"/>
                            <RowDefinition Height="6*"/>
                        </Grid.RowDefinitions>
                        <Label Content="PLC Parameter"  FontSize="25" Margin="0,10,0,0" HorizontalAlignment="Center"/>
                        <ScrollViewer Grid.Row="1"  VerticalScrollBarVisibility="Auto"   HorizontalScrollBarVisibility="Auto" Margin="10,0,10,17" Style="{StaticResource PART_ScrollViwer}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    
                                </Grid.RowDefinitions>
                                <Label Content="PLC IP" FontSize="25" Grid.Column="0" Grid.Row="0" Margin="40,0,0,0"/>
                                <Label Content="PLC Port" FontSize="25"  Grid.Column="0" Grid.Row="1" Margin="40,20,0,0"/>
                                <Label Content="PLC Heart" FontSize="25" Grid.Column="0" Grid.Row="2" Margin="40,20,0,0"/>
                                <Label Content="SendInterval"  FontSize="25" Grid.Column="0" Grid.Row="3" Margin="40,20,0,0"/>
                                <Label Content="CommunicationProtocal"  FontSize="25" Grid.Column="0" Grid.Row="4" Margin="40,20,0,0"/>
                                <ComboBox Style="{StaticResource ComboboxStyle}" MaxWidth="200" Margin="0,2,0,2" local:ComboboxHelp.CornerRadius="15" Grid.Column="1" Grid.Row="0"/>
                                <ComboBox Style="{StaticResource ComboboxStyle}" MaxWidth="200" Margin="0,20,0,2" local:ComboboxHelp.CornerRadius="15" Grid.Column="1" Grid.Row="1"/>
                                <ComboBox Style="{StaticResource ComboboxStyle}" MaxWidth="200" Margin="0,20,0,2" local:ComboboxHelp.CornerRadius="15" Grid.Column="1" Grid.Row="2"/>
                                <ComboBox Style="{StaticResource ComboboxStyle}" MaxWidth="200" Margin="0,20,0,2" local:ComboboxHelp.CornerRadius="15" Grid.Column="1" Grid.Row="3"/>
                                <ComboBox Style="{StaticResource ComboboxStyle}" MaxWidth="200" Margin="0,20,0,2" local:ComboboxHelp.CornerRadius="15" Grid.Column="1" Grid.Row="4"/>
                            </Grid>
                        </ScrollViewer>

                    </Grid>

                </Border>
                <Border Background="#ffffff" Grid.Column="1" Margin="25,25,25,25" CornerRadius="35" Style="{StaticResource BorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>

                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="1*"/>
                            <RowDefinition Height="6*"/>
                        </Grid.RowDefinitions>
                        <Label Content="MES Parameter"  FontSize="25" Margin="0,10,0,0" HorizontalAlignment="Center"/>
                        <ScrollViewer Grid.Row="1"  VerticalScrollBarVisibility="Auto"   HorizontalScrollBarVisibility="Auto" Margin="10,0,10,17" Style="{StaticResource PART_ScrollViwer}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>

                                </Grid.RowDefinitions>
                                <Label Content="MES IP" FontSize="25" Grid.Column="0" Grid.Row="0" Margin="40,0,0,0"/>
                                <Label Content="MES Port" FontSize="25"  Grid.Column="0" Grid.Row="1" Margin="40,20,0,0"/>
                                <Label Content="MES Format" FontSize="25" Grid.Column="0" Grid.Row="2" Margin="40,20,0,0"/>
                                <Label Content="CommunicationProtocol"  FontSize="25" Grid.Column="0" Grid.Row="3" Margin="40,20,0,0"/>
                                <Label Content="UploadInterval"  FontSize="25" Grid.Column="0" Grid.Row="4" Margin="40,20,0,0"/>
                                <ComboBox Style="{StaticResource ComboboxStyle}" MaxWidth="200" Margin="0,2,0,2" local:ComboboxHelp.CornerRadius="15" Grid.Column="1" Grid.Row="0"/>
                                <ComboBox Style="{StaticResource ComboboxStyle}" MaxWidth="200" Margin="0,20,0,2" local:ComboboxHelp.CornerRadius="15" Grid.Column="1" Grid.Row="1"/>
                                <ComboBox Style="{StaticResource ComboboxStyle}" MaxWidth="200" Margin="0,20,0,2" local:ComboboxHelp.CornerRadius="15" Grid.Column="1" Grid.Row="2"/>
                                <ComboBox Style="{StaticResource ComboboxStyle}" MaxWidth="200" Margin="0,20,0,2" local:ComboboxHelp.CornerRadius="15" Grid.Column="1" Grid.Row="3"/>
                                <ComboBox Style="{StaticResource ComboboxStyle}" MaxWidth="200" Margin="0,20,0,2" local:ComboboxHelp.CornerRadius="15" Grid.Column="1" Grid.Row="4"/>
                            </Grid>
                        </ScrollViewer>

                    </Grid>

                </Border>
                <Border Background="#ffffff" Grid.Column="0" Grid.Row="1" Margin="25,25,25,25" CornerRadius="35" Style="{StaticResource BorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>

                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="1*"/>
                            <RowDefinition Height="6*"/>
                        </Grid.RowDefinitions>
                        <Label Content="Robot Parameter"  FontSize="25" Margin="0,10,0,0" HorizontalAlignment="Center"/>
                        <ScrollViewer Grid.Row="1"  VerticalScrollBarVisibility="Auto"   HorizontalScrollBarVisibility="Auto" Margin="10,0,10,17" Style="{StaticResource PART_ScrollViwer}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>

                                </Grid.RowDefinitions>
                                <Label Content="Robot IP" FontSize="25" Grid.Column="0" Grid.Row="0" Margin="40,0,0,0"/>
                                <Label Content="Robot Port" FontSize="25"  Grid.Column="0" Grid.Row="1" Margin="40,20,0,0"/>
                                <Label Content="Robot Heart" FontSize="25" Grid.Column="0" Grid.Row="2" Margin="40,20,0,0"/>
                                <Label Content="CommunicationProtocol"  FontSize="25" Grid.Column="0" Grid.Row="3" Margin="40,20,0,0"/>
                                <ComboBox Style="{StaticResource ComboboxStyle}" MaxWidth="200" Margin="0,2,0,2" local:ComboboxHelp.CornerRadius="15" Grid.Column="1" Grid.Row="0"/>
                                <ComboBox Style="{StaticResource ComboboxStyle}" MaxWidth="200" Margin="0,20,0,2" local:ComboboxHelp.CornerRadius="15" Grid.Column="1" Grid.Row="1"/>
                                <ComboBox Style="{StaticResource ComboboxStyle}" MaxWidth="200" Margin="0,20,0,2" local:ComboboxHelp.CornerRadius="15" Grid.Column="1" Grid.Row="2"/>
                                <ComboBox Style="{StaticResource ComboboxStyle}" MaxWidth="200" Margin="0,20,0,2" local:ComboboxHelp.CornerRadius="15" Grid.Column="1" Grid.Row="3"/>
                            </Grid>
                        </ScrollViewer>

                    </Grid>

                </Border>

                <Border Background="#ffffff" Grid.Column="1" Grid.Row="1" Margin="25,25,25,25" CornerRadius="35" Style="{StaticResource BorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>

                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="1*"/>
                            <RowDefinition Height="6*"/>
                        </Grid.RowDefinitions>
                        <Label Content="Camera Parameter"  FontSize="25" Margin="0,10,0,0" HorizontalAlignment="Center"/>
                        <ScrollViewer Grid.Row="1"  VerticalScrollBarVisibility="Auto"   HorizontalScrollBarVisibility="Auto" Margin="10,0,10,17" Style="{StaticResource PART_ScrollViwer}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="auto"/>
                                    <RowDefinition Height="auto"/>
                                </Grid.RowDefinitions>
                                <Label Content="CameraNumber" FontSize="25" Grid.Column="0" Grid.Row="0" Margin="40,0,0,0"/>
                                <ComboBox Style="{StaticResource ComboboxStyle}" MaxWidth="200" Margin="0,0,0,2"  local:ComboboxHelp.CornerRadius="15" Grid.Column="1" Grid.Row="0"/>

                                <ContentControl Grid.Row="1" Grid.ColumnSpan="2"/>
                            </Grid>
                            
                            
                        </ScrollViewer>

                    </Grid>

                </Border>

            </Grid>
        </Border>
    </Grid>
</UserControl>
