<Window x:Class="FirstVisionView.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FirstVisionView"
        mc:Ignorable="d"
        Title="MainWindow" Height="1050" Width="1680" Background="#F5F5F7">

    <Window.Resources>
        <!--卡片式菜单下的按钮，透明圆角版-->
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Board"
                                Background="{TemplateBinding Background}"  
                                BorderBrush="{TemplateBinding BorderBrush}"  
                                BorderThickness="{TemplateBinding BorderThickness}"  
                                CornerRadius="8"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Board" Property="Width" Value="80"/>
                                <Setter TargetName="Board" Property="Height" Value="25"/>
                                <Setter TargetName="Board" Property="CornerRadius" Value="8"/>

                                <Setter TargetName="Board" Property="Background" Value="#FF9A9191"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Board" Property="Background" Value="#FF464343"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!--普通按钮圆角版-->
        <Style x:Key="ButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FFECE8E8"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalAlignment" Value="stretch"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="Width" Value="35"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Padding" Value="0,0,0,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">

                        <Border x:Name="Board"
                                    Background="{TemplateBinding Background}"  
                                    BorderBrush="{TemplateBinding BorderBrush}"  
                                    BorderThickness="{TemplateBinding BorderThickness}"  
                                    Width="{TemplateBinding Width}"
                                    Height="{TemplateBinding Height}"
                                    CornerRadius="{Binding Path=(local:ButtonHelp.CornerRadius),RelativeSource={RelativeSource TemplatedParent}}"
                                    HorizontalAlignment="{TemplateBinding HorizontalAlignment}"
                                    Padding="{TemplateBinding Padding}"
                                    VerticalAlignment="{TemplateBinding VerticalAlignment}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" Margin="-0.5,0,0,2" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>




                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">

                                <Setter TargetName="Board" Property="Background" Value="#FF9A9191"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Board" Property="Background" Value="#FF464343"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!--圆角Border-->
        <Style x:Key="PopupBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#E5E5E5"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
        <!--普通下拉列表圆角版-->
        <Style x:Key="ComboboxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#FFECE8E8"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="Black"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="local:ComboboxHelp.CornerRadius" Value="18"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid >
                            
                   
                        <Border  Background="{TemplateBinding Background}" CornerRadius="{Binding Path=(local:ComboboxHelp.CornerRadius),RelativeSource={RelativeSource AncestorType=ComboBox}}">
                                <ToggleButton x:Name="ToggleButton" 
                                                IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}" >
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="30"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.ColumnSpan="2" Background="Transparent" CornerRadius="{Binding Path=(local:ComboboxHelp.CornerRadius),RelativeSource={RelativeSource AncestorType=ComboBox}}"/>
                                            <ContentPresenter Grid.Column ="0" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            <Path Grid.Column ="1" Data="M0 0 L4 4 L8 0" Fill="Black" Width="8" Height="4" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Grid>
                                    </ControlTemplate>

                                </ToggleButton.Template>
                            </ToggleButton>
                        </Border>
                           <Popup x:Name="PART_Popup"
                                  IsOpen="{TemplateBinding IsDropDownOpen}"
                                  PlacementTarget="{Binding ElementName=ToggleButton}"
                                  Placement="Bottom"
                                  AllowsTransparency="True"
                                  VerticalOffset="12" 
                                  Focusable="False">
                                    
                                <Border Style="{StaticResource PopupBorderStyle}">
                                    <StackPanel>
                                        <Border Height="{TemplateBinding Height}" Width="{TemplateBinding Width}" CornerRadius="8"/>
                                        <Button Content="test" Width="{TemplateBinding Width}"  Style="{StaticResource ButtonStyle}"/>
                                        <Button Content="test" Style="{StaticResource ButtonStyle}"/>
                                    </StackPanel>
                                    
                                </Border>
                                


                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="3*"/>

        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <!--工具栏-->
        <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Height="52" Width="1680" Grid.Column="0" Grid.Row="0"  Grid.ColumnSpan="10" Orientation="Horizontal" Background="#FFECE8E8">
            <Button x:Name="File" Content="文件" Width="75" Height="23" Margin="10,10,0,10" Click="Button_Click"  BorderBrush="{x:Null}" Background="{x:Null}" FontSize="16" Style="{StaticResource ButtonStyle}"/>
            <Button x:Name="Tools" Content="工具" Command="{Binding ToolsButtonClick}" Width="75" Height="23" Margin="30,10,0,10" BorderBrush="{x:Null}" Background="{x:Null}" FontSize="16" Style="{StaticResource ButtonStyle}" Click="Tools_Click"/>
            <Button x:Name="View" Content="视图" Width="75" Height="23" Margin="30,10,0,10" BorderBrush="{x:Null}" Background="{x:Null}" FontSize="16" Style="{StaticResource ButtonStyle}"/>
        </StackPanel>
        <!--左侧面板-->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>

            </Grid.RowDefinitions>
            <!--导航栏-->
            <Border Grid.Column="0" Background="#FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Top" Width="50" Height="800" CornerRadius="20" Margin="0,50,0,0">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="1"
                                    BlurRadius="10"  
                                       Color="#20000000"
                                      Opacity="0.5">
                    </DropShadowEffect>
                </Border.Effect>

                <StackPanel HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Grid.Row="1" Grid.RowSpan="2" Background="Transparent" >
                    <Button Content="🏠" HorizontalAlignment="Center" FontSize="16" Margin="0,20,0,20" Style="{StaticResource ButtonStyle}"/>
                    <Button  Content="🧾" HorizontalAlignment="Center" FontSize="16" Margin="0,20,0,20" Style="{StaticResource ButtonStyle}"/>
                </StackPanel>
            </Border>

            <StackPanel Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" >
                <!--参数Card1-->
                <Border Height="150" Width="320" Background="#FFFFFF" Margin="0,50,0,0" CornerRadius="20">
                    <Border.Effect >
                        <DropShadowEffect ShadowDepth="1"       
                                          BlurRadius="10"
                                          Color="#20000000"
                                          Opacity="0.3"/>
                    </Border.Effect>
                </Border>
                <!--参数Card2-->
                <Border Height="150" Width="320" Background="#FFFFFF" Margin="0,50,0,0" CornerRadius="20">
                    <Border.Effect >
                        <DropShadowEffect ShadowDepth="1"       
                          BlurRadius="10"
                          Color="#20000000"
                          Opacity="0.3"/>
                    </Border.Effect>
                </Border>
                <!--参数Card3-->
                <Border Height="150" Width="320" Background="#FFFFFF" Margin="0,50,0,0" CornerRadius="20">
                    <Border.Effect >
                        <DropShadowEffect ShadowDepth="1"       
                          BlurRadius="10"
                          Color="#20000000"
                          Opacity="0.3"/>
                    </Border.Effect>
                </Border>

                <!--参数Card4-->
                <Border Height="150" Width="320" Background="#FFFFFF" Margin="0,50,0,0" CornerRadius="20">
                    <Border.Effect >
                        <DropShadowEffect ShadowDepth="1"       
                          BlurRadius="10"
                          Color="#20000000"
                          Opacity="0.3"/>
                    </Border.Effect>
                </Border>
            </StackPanel>   
         



        </Grid>

        <!--右侧区域-->
        <Grid Grid.Column="1" Grid.Row="1" >
            <Grid.RowDefinitions>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="19*"/>
            </Grid.RowDefinitions>
            <!--图像显示调整栏的底色-->
            <Border Background="#FFFFFF"  BorderBrush="#FFFFFF" HorizontalAlignment="Stretch" >
                <!-- 轻微垂直偏移 -->
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="1"       
                    BlurRadius="10"
                    Color="#20000000"
                    Opacity="0.3"/>
                </Border.Effect>
            </Border>
            <!--图像栏布局-->
            <!--图层选择列表-->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,0">
                <ComboBox x:Name="LayerSelection"  HorizontalAlignment="Stretch"  VerticalAlignment="Stretch" Width="200" MaxHeight="35" Style="{StaticResource ComboboxStyle}"/>
                <ComboBox x:Name="CameraSelection"   Margin="30,0,0,0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Width="100" MaxHeight="35" Style="{StaticResource ComboboxStyle}"/>
                <!--放大-->
                <Button x:Name="Enlarge" Margin="30,0,0,0" Content="➕" FontSize="25" Foreground="Gray" local:ButtonHelp.CornerRadius="17.5"  Style="{StaticResource ButtonStyle}" />
                <!--缩小-->
                <Button x:Name="Reduce" Margin="10,0,0,0" Content="➖" FontSize="25" Foreground="Gray" local:ButtonHelp.CornerRadius="17.5"  Style="{StaticResource ButtonStyle}" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="R:" Grid.Column="1" HorizontalAlignment="Center" FontSize="25"/>
                    <Label x:Name="RValue" Content="" Grid.Column="2"  Margin="10,0,15,0" HorizontalAlignment="Center" FontSize="25"/>
                    <Label Content="G:"  Grid.Column="3" HorizontalAlignment="Center" FontSize="25"/>
                    <Label x:Name="GValue" Content=""  Grid.Column="4" HorizontalAlignment="Center" FontSize="25"/>
                    <Label Content="B:" Grid.Column="5" HorizontalAlignment="Center" FontSize="25"/>
                    <Label x:Name="BValue" Content=""  Grid.Column="6" HorizontalAlignment="Center" FontSize="25"/>
                    <Label Content="H:" Grid.Column="7" HorizontalAlignment="Center" FontSize="25"/>
                    <Label x:Name="HValue" Content="" Grid.Column="8" HorizontalAlignment="Center" FontSize="25"/>
                    <Label Content="S:" Grid.Column="9" HorizontalAlignment="Center" FontSize="25"/>
                    <Label x:Name="SValue" Content=""  Grid.Column="10" HorizontalAlignment="Center" FontSize="25"/>
                    <Label Content="V:" Grid.Column="11" HorizontalAlignment="Center" FontSize="25"/>
                    <Label x:Name="VValue" Content=""  Grid.Column="12" HorizontalAlignment="Center" FontSize="25"/>
                </Grid>

            </StackPanel>
            <!--图像显示窗口-->
            <Image x:Name="imgDisplay" Grid.Row="1" Grid.Column="0" Source="/Pictrue.jpg"
                   Stretch="None"
                   RenderOptions.BitmapScalingMode="NearestNeighbor" 
                   MouseLeftButtonDown="imgDisplay_MouseLeftButtonDown"
                   MouseLeftButtonUp="imgDisplay_MouseLeftButtonUp" 
                   MouseMove="imgDisplay_MouseMove" 
                   MouseWheel="imgDisplay_MouseWheel">
                <!--图像操作：旋转/平移/缩放-->
                <Image.RenderTransform>
                    <!--缩放组合-->
                    <TransformGroup>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                        <TranslateTransform X="0" Y="0"/>
                    </TransformGroup>
                </Image.RenderTransform>
            </Image>
            <!--ROI区域-->
            <Canvas Grid.Row="1" Grid.Column="0" x:Name="ROI" Background="Transparent" IsHitTestVisible="True" RenderTransform="{Binding ElementName=imgDisplay,Path=RenderTransform}" />
        </Grid>
        <!--文件菜单-->
        <Popup x:Name="FilePopup"
       PlacementTarget="{Binding ElementName=File}"
       Placement="Bottom"
       AllowsTransparency="True"
       StaysOpen="False">
            <Border Background="#E5E5E5" BorderBrush="#D0D0D0" BorderThickness="1" MaxWidth="200" Width="90" CornerRadius="8">
                <StackPanel>
                    <Button Content="新建项目" Width="100" Height="30" Style="{StaticResource MenuButtonStyle}"/>
                    <Button Content="打开项目" Width="100" Height="30" Style="{StaticResource MenuButtonStyle}"/>
                    <Button Content="保存项目" Width="100" Height="30" Style="{StaticResource MenuButtonStyle}"/>
                    <Button  Content="另存为" Width="100" Height="30" Style="{StaticResource MenuButtonStyle}"/>
                    <Button  Content="退出" Width="100" Height="30" Style="{StaticResource MenuButtonStyle}"/>
                </StackPanel>
            </Border>
        </Popup>
        <Popup x:Name="ToolsPopup" 
               PlacementTarget="{Binding ElementName=Tools}"
               Placement="Bottom"
               IsOpen="{Binding IsToolsPopupOpen,Mode=TwoWay}"
               AllowsTransparency="True"
               StaysOpen="False">
            <Border Background="#E5E5E5" BorderBrush="#D0D0D0" BorderThickness="1" MaxWidth="200" Width="90" CornerRadius="8">
                <StackPanel>
                    <Button Content="新建项目" Width="100" Height="30" Style="{StaticResource MenuButtonStyle}"/>
                    <Button Content="打开项目" Width="100" Height="30" Style="{StaticResource MenuButtonStyle}"/>
                    <Button Content="保存项目" Width="100" Height="30" Style="{StaticResource MenuButtonStyle}"/>
                    <Button  Content="另存为" Width="100" Height="30" Style="{StaticResource MenuButtonStyle}"/>
                    <Button  Content="退出" Width="100" Height="30" Style="{StaticResource MenuButtonStyle}"/>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>



</Window>
