<Window x:Class="FirstVisionView.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FirstVisionView"
        mc:Ignorable="d"
        Title="MainWindow" MinHeight="1050" MinWidth="1680" WindowState="Maximized" Background="#F5F5F7" >

    <Grid>
        <Grid.ColumnDefinitions>

        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <!--工具栏-->
        <StackPanel  VerticalAlignment="Top" Height="50"  Grid.Column="0" Grid.Row="0"   Orientation="Horizontal" Background="#FFECE8E8">
            <Button x:Name="File" Content="文件" Width="75" Height="23" Margin="10,10,0,10"   BorderBrush="{x:Null}" Background="{x:Null}" FontSize="16" Style="{StaticResource ButtonStyle}"/>
            <Button x:Name="Tools" Content="工具"  Width="75" Height="23" Margin="30,10,0,10" BorderBrush="{x:Null}" Background="{x:Null}" FontSize="16" Style="{StaticResource ButtonStyle}"/>
            <Button x:Name="View" Content="视图" Width="75" Height="23" Margin="30,10,0,10" BorderBrush="{x:Null}" Background="{x:Null}" FontSize="16" Style="{StaticResource ButtonStyle}"/>
        </StackPanel>
        <!--左侧面板-->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>

            </Grid.RowDefinitions>
            <!--导航栏-->
            <Border Grid.Column="0" Background="#FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center" Width="50" Height="800" CornerRadius="20" >
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="1"
                                    BlurRadius="10"  
                                       Color="#20000000"
                                      Opacity="0.5">
                    </DropShadowEffect>
                </Border.Effect>

                <StackPanel  Grid.Row="1" Grid.RowSpan="2" Background="Transparent" >
                    <Button Content="🏠" HorizontalAlignment="Center" FontSize="16" Margin="0,20,0,20" Style="{StaticResource ButtonStyle}" Click="Button_Click_1"/>
                    <Button  Content="🧾" HorizontalAlignment="Center" FontSize="16" Margin="0,20,0,20" Style="{StaticResource ButtonStyle}" Click="Button_Click"/>
                    <Button  Content="⚙" HorizontalAlignment="Center" FontSize="16" Margin="0,20,0,20" Style="{StaticResource ButtonStyle}" Click="Button_Click"/>
                </StackPanel>
            </Border>
            <!--Page切换-->
            <ContentControl x:Name="Page" Grid.Column="1" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch"/>





        </Grid>


        <Popup x:Name="ToolsPopup" 
               PlacementTarget="{Binding ElementName=Tools}"
               Placement="Bottom"
             
               AllowsTransparency="True"
               StaysOpen="False">
            <Border Background="#E5E5E5" BorderBrush="#D0D0D0" BorderThickness="1" MaxWidth="200" Width="90" CornerRadius="8">
                <StackPanel>
                    <Button Content="新建项目" Width="100" Height="30" Style="{StaticResource MenuButtonStyle}"/>
                    <Button Content="打开项目" Width="100" Height="30" Style="{StaticResource MenuButtonStyle}"/>
                    <Button Content="保存项目" Width="100" Height="30" Style="{StaticResource MenuButtonStyle}"/>
                    <Button  Content="另存为" Width="100" Height="30" Style="{StaticResource MenuButtonStyle}"/>
                    <Button  Content="退出" Width="100" Height="30" Style="{StaticResource MenuButtonStyle}"/>
                </StackPanel>
            </Border>
        </Popup>
        <!--文件菜单-->
        <Popup x:Name="FilePopup"
PlacementTarget="{Binding ElementName=File}"
Placement="Bottom"
AllowsTransparency="True"
StaysOpen="False">
            <Border Background="#E5E5E5" BorderBrush="#D0D0D0" BorderThickness="1" MaxWidth="200" Width="90" CornerRadius="8">
                <StackPanel>
                    <Button Content="新建项目" Width="100" Height="30" Style="{StaticResource MenuButtonStyle}"/>
                    <Button Content="打开项目" Width="100" Height="30" Style="{StaticResource MenuButtonStyle}"/>
                    <Button Content="保存项目" Width="100" Height="30" Style="{StaticResource MenuButtonStyle}"/>
                    <Button  Content="另存为" Width="100" Height="30" Style="{StaticResource MenuButtonStyle}"/>
                    <Button  Content="退出" Width="100" Height="30" Style="{StaticResource MenuButtonStyle}"/>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>



</Window>
